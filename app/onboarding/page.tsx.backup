'use client'

import { useState, useRef } from 'react'
import { useRouter } from 'next/navigation'
import { Syne, Space_Grotesk } from 'next/font/google'
import { getSupabaseClient } from '@/lib/supabase'

const syne = Syne({
  subsets: ['latin'],
  weight: ['400', '600', '700', '800'],
  variable: '--font-syne',
})

const spaceGrotesk = Space_Grotesk({
  subsets: ['latin'],
  weight: ['300', '400', '500', '600', '700'],
  variable: '--font-space',
})

// ── Data ──────────────────────────────────────────────────────────────────────

const EVENT_TYPES = [
  { icon: '💍', label: 'Wedding',        sub: 'Local or destination' },
  { icon: '🎂', label: 'Birthday',       sub: 'Any age, any scale' },
  { icon: '🏢', label: 'Corporate',      sub: 'Conferences, galas' },
  { icon: '🎉', label: 'Social Party',   sub: 'Friends & family' },
  { icon: '👶', label: 'Baby Shower',    sub: 'Gender reveals too' },
  { icon: '🎓', label: 'Graduation',     sub: 'All levels' },
  { icon: '🎪', label: 'Kids Party',     sub: 'Play places & more' },
  { icon: '✨', label: 'Something Else', sub: "We've got you" },
]

const KEYWORDS = [
  'Candlelit', 'Outdoor', 'Rooftop', 'Garden', 'Ballroom', 'Tropical',
  'Fairy Lights', 'Floral Wall', 'Black Tie', 'Casual Chic', 'Sunset',
  'Dance Floor', 'Waterfront', 'Minimalist', 'Maximalist', 'Cultural',
]

const COLOR_SWATCHES = [
  { color: '#F5E6D3', name: 'Champagne' },
  { color: '#1A1A2E', name: 'Midnight' },
  { color: '#D4AF37', name: 'Gold' },
  { color: '#C0392B', name: 'Deep Red' },
  { color: '#F8C8D4', name: 'Blush' },
  { color: '#2ECC71', name: 'Sage' },
  { color: '#5DADE2', name: 'Sky Blue' },
  { color: '#784212', name: 'Terracotta' },
  { color: '#DDB8F5', name: 'Lavender' },
  { color: '#F0F0F0', name: 'White', hasBorder: true },
]

const BUDGET_PRESETS = [
  { label: '$2.5K',  value: 2500 },
  { label: '$5K',    value: 5000 },
  { label: '$15K',   value: 15000 },
  { label: '$50K',   value: 50000 },
  { label: '$250K+', value: 250000 },
]

const TIERS = [
  { icon: '🌱', name: 'Affordable',     range: 'Budget-friendly picks' },
  { icon: '✨', name: 'Mid-Range',      range: 'Best value vendors' },
  { icon: '💎', name: 'Luxury',         range: 'Premium experience' },
  { icon: '👑', name: 'Ultra High-End', range: 'No limits' },
]

const MOOD_EMOJIS: Record<string, string> = {
  Candlelit: '🕯️', Outdoor: '🌿', Rooftop: '🌆', Garden: '🌸',
  Ballroom: '💃', Tropical: '🌴', 'Fairy Lights': '✨', 'Floral Wall': '🌺',
  'Black Tie': '🎩', 'Casual Chic': '👗', Sunset: '🌅', 'Dance Floor': '🪩',
  Waterfront: '🌊', Minimalist: '⬜', Maximalist: '🎆', Cultural: '🎭',
}

const FALLBACK_MOODS = ['🌿', '🕯️', '🌸', '🥂', '✨']

// ── Shared sub-components ─────────────────────────────────────────────────────

function ProgressBar({ done }: { done: number }) {
  return (
    <div className="flex gap-1.5 mb-6">
      {Array.from({ length: 6 }).map((_, i) => (
        <div
          key={i}
          className="h-1 flex-1 rounded-full transition-colors duration-300"
          style={{ background: i < done ? 'var(--plum)' : 'var(--lavender)' }}
        />
      ))}
    </div>
  )
}

function BackBtn({ onClick }: { onClick: () => void }) {
  return (
    <button
      onClick={onClick}
      className="w-10 h-10 rounded-xl border-none cursor-pointer flex items-center justify-center text-lg mb-5 hover:-translate-x-0.5 transition-transform duration-150"
      style={{
        background: 'white',
        color: 'var(--charcoal)',
        boxShadow: '0 2px 8px rgba(74,14,110,0.1)',
      }}
    >←</button>
  )
}

function NavDots({ active }: { active: number }) {
  return (
    <div className="flex justify-center gap-2 py-3 flex-shrink-0">
      {Array.from({ length: 6 }).map((_, i) => (
        <div
          key={i}
          className="h-1.5 rounded-full transition-all duration-300"
          style={{
            width: i === active ? '24px' : '6px',
            background: i === active ? 'var(--plum)' : 'var(--lavender)',
          }}
        />
      ))}
    </div>
  )
}

function NextBtn({
  label,
  onClick,
  disabled,
}: {
  label: string
  onClick: () => void
  disabled?: boolean
}) {
  return (
    <button
      onClick={onClick}
      disabled={disabled}
      className="w-full text-white text-[15px] font-bold border-none rounded-2xl py-5 cursor-pointer tracking-[-0.3px] flex items-center justify-center gap-2 transition-all duration-150 disabled:opacity-60 disabled:cursor-not-allowed"
      style={{
        fontFamily: 'var(--font-syne)',
        background: 'var(--plum)',
        boxShadow: disabled ? 'none' : '0 4px 20px rgba(74,14,110,0.25)',
      }}
      onMouseEnter={e => {
        if (!disabled) {
          const el = e.currentTarget as HTMLButtonElement
          el.style.transform = 'translateY(-2px)'
          el.style.boxShadow = '0 8px 24px rgba(74,14,110,0.35)'
        }
      }}
      onMouseLeave={e => {
        const el = e.currentTarget as HTMLButtonElement
        el.style.transform = 'translateY(0)'
        el.style.boxShadow = disabled ? 'none' : '0 4px 20px rgba(74,14,110,0.25)'
      }}
    >{label}</button>
  )
}

function SectionLabel({ children }: { children: React.ReactNode }) {
  return (
    <div
      className="text-[11px] font-bold tracking-[1.8px] uppercase mb-3"
      style={{ fontFamily: 'var(--font-syne)', color: 'var(--muted)' }}
    >{children}</div>
  )
}

function InputField(props: React.InputHTMLAttributes<HTMLInputElement>) {
  return (
    <input
      {...props}
      className={`w-full bg-white border-2 rounded-2xl px-4 py-4 text-[15px] outline-none transition-colors duration-200 placeholder:text-[#C0ACD4] ${props.className ?? ''}`}
      style={{
        fontFamily: 'var(--font-space)',
        color: 'var(--charcoal)',
        borderColor: 'var(--lavender)',
        boxShadow: '0 2px 8px rgba(74,14,110,0.04)',
        ...props.style,
      }}
      onFocus={e => { e.currentTarget.style.borderColor = 'var(--plum)'; props.onFocus?.(e) }}
      onBlur={e => { e.currentTarget.style.borderColor = 'var(--lavender)'; props.onBlur?.(e) }}
    />
  )
}

// ── Step layout shell ─────────────────────────────────────────────────────────
// Provides sticky header + scrollable body + sticky footer within full viewport.

function StepShell({
  header,
  body,
  footer,
}: {
  header: React.ReactNode
  body: React.ReactNode
  footer: React.ReactNode
}) {
  return (
    <div className="h-screen flex flex-col overflow-hidden" style={{ background: 'var(--lavender-light)' }}>
      <div className="flex-1 flex flex-col min-h-0 w-full max-w-[480px] mx-auto">
        {/* sticky header */}
        <div className="flex-shrink-0 px-6 pt-10 pb-2">{header}</div>
        {/* scrollable body */}
        <div className="flex-1 overflow-y-auto px-6 pt-2 scrollbar-hide">{body}</div>
        {/* sticky footer */}
        <div className="flex-shrink-0 px-6 pb-10 pt-2">{footer}</div>
      </div>
    </div>
  )
}

// ── Page component ────────────────────────────────────────────────────────────

export default function OnboardingPage() {
  const router = useRouter()

  const [screen, setScreen]                     = useState(0)
  const [eventType, setEventType]               = useState<string | null>(null)
  const [dreamText, setDreamText]               = useState('')
  const [selectedKeywords, setSelectedKeywords] = useState<Set<string>>(new Set())
  const [selectedColors, setSelectedColors]     = useState<string[]>([])
  const [eventDate, setEventDate]               = useState('')
  const [isDestination, setIsDestination]       = useState<boolean | null>(null)
  const [location, setLocation]                 = useState('')
  const [guestCount, setGuestCount]             = useState('')
  const [duration, setDuration]                 = useState('')
  const [requirements, setRequirements]         = useState('')
  const [budget, setBudget]                     = useState(5000)
  const [selectedTier, setSelectedTier]         = useState<string | null>(null)
  const [previewImages, setPreviewImages]       = useState<string[]>([])
  const [generating, setGenerating]             = useState(false)
  const fileInputRef = useRef<HTMLInputElement>(null)

  function toggleKeyword(kw: string) {
    setSelectedKeywords(prev => {
      const next = new Set(prev)
      next.has(kw) ? next.delete(kw) : next.add(kw)
      return next
    })
  }

  function toggleColor(name: string) {
    setSelectedColors(prev =>
      prev.includes(name) ? prev.filter(c => c !== name) : [...prev, name]
    )
  }

  function handleFileChange(e: React.ChangeEvent<HTMLInputElement>) {
    const files = Array.from(e.target.files ?? []).slice(0, 6)
    setPreviewImages(files.map(f => URL.createObjectURL(f)))
  }

  async function handleGenerate() {
    setGenerating(true)
    setScreen(6)

    try {
      const supabase = getSupabaseClient()
      const { data: { user } } = await supabase.auth.getUser()

      await supabase.from('events').insert({
        client_id:            user?.id ?? null,
        event_type:           eventType,
        description:          dreamText,
        keywords:             Array.from(selectedKeywords),
        colors:               selectedColors,
        event_date:           eventDate || null,
        location:             location || null,
        guest_count:          guestCount ? parseInt(guestCount, 10) : null,
        duration:             duration || null,
        special_requirements: requirements || null,
        total_budget:         budget,
        tier:                 selectedTier,
        status:               'planning',
        created_at:           new Date().toISOString(),
      })

      await new Promise(r => setTimeout(r, 2800))
      router.push('/ai-plan')
    } catch {
      await new Promise(r => setTimeout(r, 2800))
      router.push('/ai-plan')
    }
  }

  const moodThumbs = selectedKeywords.size > 0
    ? Array.from(selectedKeywords).slice(0, 5).map(kw => MOOD_EMOJIS[kw] ?? '✨')
    : FALLBACK_MOODS

  return (
    <div
      className={`${syne.variable} ${spaceGrotesk.variable}`}
      style={{ fontFamily: 'var(--font-space), sans-serif' }}
    >
      {/* ── SCREEN 0: SPLASH ─────────────────────────────────────────────── */}
      {screen === 0 && (
        <div
          className="min-h-screen flex flex-col items-center justify-center px-6 py-16 relative overflow-hidden animate-slide-in"
          style={{ background: 'var(--plum)' }}
        >
          {/* decorative glow */}
          <div
            aria-hidden
            className="absolute rounded-full pointer-events-none"
            style={{
              width: '600px', height: '600px',
              background: 'radial-gradient(circle, rgba(221,184,245,0.12) 0%, transparent 70%)',
              top: '-120px', right: '-180px',
            }}
          />
          <div
            aria-hidden
            className="absolute rounded-full pointer-events-none"
            style={{
              width: '400px', height: '400px',
              background: 'radial-gradient(circle, rgba(221,184,245,0.08) 0%, transparent 70%)',
              bottom: '-80px', left: '-120px',
            }}
          />

          <div className="w-full max-w-[480px] flex flex-col items-center relative z-[1]">
            <div
              className="w-20 h-20 bg-white/[0.12] rounded-3xl flex items-center justify-center text-[38px] mb-8"
              style={{ animation: 'popIn 0.6s 0.2s cubic-bezier(0.16,1,0.3,1) both' }}
            >✦</div>

            <div
              className="text-[52px] font-extrabold text-white tracking-[-2px] text-center leading-none mb-1"
              style={{
                fontFamily: 'var(--font-syne)',
                animation: 'fadeUp 0.6s 0.35s ease both',
              }}
            >evnti.</div>

            <div
              className="text-[13px] text-white/50 tracking-[2.5px] uppercase mt-3 mb-8"
              style={{ animation: 'fadeUp 0.6s 0.45s ease both' }}
            >Planning made effortless.</div>

            <div
              className="text-[17px] text-white/70 text-center leading-[1.75] mb-12"
              style={{ animation: 'fadeUp 0.6s 0.55s ease both' }}
            >
              Your AI-powered event planner. From kids&apos; play parties to Lake Como
              weddings — we handle every single detail.
            </div>

            <button
              className="w-full bg-white text-[16px] font-bold border-none rounded-2xl py-5 cursor-pointer hover:-translate-y-0.5 hover:shadow-[0_8px_24px_rgba(0,0,0,0.2)] transition-all duration-150"
              style={{
                fontFamily: 'var(--font-syne)',
                color: 'var(--plum)',
                animation: 'fadeUp 0.6s 0.65s ease both',
              }}
              onClick={() => setScreen(1)}
            >Start Planning ✦</button>

            <div
              className="mt-5 text-[14px] text-white/40"
              style={{ animation: 'fadeUp 0.6s 0.75s ease both' }}
            >
              Already have an account?{' '}
              <span className="text-white/80 font-medium cursor-pointer underline underline-offset-[3px]">
                Log in
              </span>
            </div>
          </div>
        </div>
      )}

      {/* ── SCREEN 1: EVENT TYPE ─────────────────────────────────────────── */}
      {screen === 1 && (
        <StepShell
          header={
            <>
              <ProgressBar done={1} />
              <BackBtn onClick={() => setScreen(0)} />
              <div className="text-[11px] tracking-[2px] uppercase mb-1" style={{ color: 'var(--muted)' }}>
                Step 1 of 6
              </div>
              <div
                className="text-[26px] font-bold tracking-[-0.5px] leading-tight"
                style={{ fontFamily: 'var(--font-syne)', color: 'var(--charcoal)' }}
              >What are we celebrating?</div>
            </>
          }
          body={
            <div className="grid grid-cols-2 gap-3 pt-2 pb-4">
              {EVENT_TYPES.map(({ icon, label, sub }) => (
                <div
                  key={label}
                  className="bg-white border-2 rounded-2xl p-4 cursor-pointer transition-all duration-200 hover:-translate-y-px"
                  style={{
                    borderColor: eventType === label ? 'var(--plum)' : 'transparent',
                    background: eventType === label ? 'var(--lavender-light)' : 'white',
                    boxShadow: '0 2px 12px rgba(74,14,110,0.07)',
                  }}
                  onClick={() => setEventType(label)}
                  onMouseEnter={e => {
                    if (eventType !== label)
                      (e.currentTarget as HTMLElement).style.borderColor = 'var(--lavender)'
                  }}
                  onMouseLeave={e => {
                    if (eventType !== label)
                      (e.currentTarget as HTMLElement).style.borderColor = 'transparent'
                  }}
                >
                  <span className="text-[26px] mb-2 block">{icon}</span>
                  <div
                    className="text-[13px] font-bold"
                    style={{ fontFamily: 'var(--font-syne)', color: 'var(--charcoal)' }}
                  >{label}</div>
                  <div className="text-[11px] mt-0.5" style={{ color: 'var(--muted)' }}>{sub}</div>
                </div>
              ))}
            </div>
          }
          footer={
            <>
              <NavDots active={0} />
              <NextBtn label="Continue →" onClick={() => setScreen(2)} />
            </>
          }
        />
      )}

      {/* ── SCREEN 2: DESCRIBE YOUR EVENT ────────────────────────────────── */}
      {screen === 2 && (
        <StepShell
          header={
            <>
              <ProgressBar done={2} />
              <BackBtn onClick={() => setScreen(1)} />
              <div className="text-[11px] tracking-[2px] uppercase mb-1" style={{ color: 'var(--muted)' }}>
                Step 2 of 6
              </div>
              <div
                className="text-[26px] font-bold tracking-[-0.5px] leading-tight"
                style={{ fontFamily: 'var(--font-syne)', color: 'var(--charcoal)' }}
              >Paint us a picture of your event.</div>
              <div className="text-[14px] mt-2 leading-[1.55]" style={{ color: 'var(--muted)' }}>
                Describe it like you&apos;re telling a friend your dream. The more detail, the better we curate.
              </div>
            </>
          }
          body={
            <div className="pt-2 pb-4">
              {/* Dream description */}
              <textarea
                rows={4}
                className="w-full bg-white border-2 rounded-2xl p-4 text-[15px] resize-none outline-none leading-[1.7] min-h-[110px] mb-5 transition-colors duration-200 placeholder:text-[#C0ACD4] placeholder:italic"
                style={{
                  fontFamily: 'var(--font-space)',
                  color: 'var(--charcoal)',
                  borderColor: 'var(--lavender)',
                  boxShadow: '0 2px 8px rgba(74,14,110,0.04)',
                }}
                placeholder="e.g. 'An intimate outdoor dinner at sunset for 50 people. Think fairy lights, long tables, lush florals, Afrobeats transitioning to R&B, and a full open bar…'"
                value={dreamText}
                onChange={e => setDreamText(e.target.value)}
                onFocus={e => { e.currentTarget.style.borderColor = 'var(--plum)' }}
                onBlur={e => { e.currentTarget.style.borderColor = 'var(--lavender)' }}
              />

              {/* Mood board upload */}
              <SectionLabel>Add Inspiration Images</SectionLabel>
              <div
                className="border-2 border-dashed rounded-2xl p-6 text-center cursor-pointer transition-all duration-200 bg-white mb-4"
                style={{ borderColor: 'var(--lavender)' }}
                onClick={() => fileInputRef.current?.click()}
                onMouseEnter={e => {
                  const el = e.currentTarget as HTMLElement
                  el.style.borderColor = 'var(--plum)'
                  el.style.background = 'var(--lavender-light)'
                }}
                onMouseLeave={e => {
                  const el = e.currentTarget as HTMLElement
                  el.style.borderColor = 'var(--lavender)'
                  el.style.background = 'white'
                }}
              >
                <input
                  ref={fileInputRef}
                  type="file"
                  multiple
                  accept="image/*"
                  className="hidden"
                  onChange={handleFileChange}
                />
                <div className="text-[32px] mb-2">🖼️</div>
                <div
                  className="text-[14px] font-bold"
                  style={{ fontFamily: 'var(--font-syne)', color: 'var(--plum)' }}
                >Upload from camera roll</div>
                <div className="text-[12px] mt-1" style={{ color: 'var(--muted)' }}>
                  Pinterest screenshots, inspo pics, anything
                </div>
              </div>

              {/* Image preview grid */}
              <div className="grid grid-cols-3 gap-2 mb-5">
                {previewImages.map((src, i) => (
                  <img
                    key={i}
                    src={src}
                    alt=""
                    className="aspect-square rounded-xl object-cover w-full"
                    style={{ animation: 'popIn 0.3s ease both' }}
                  />
                ))}
                {Array.from({ length: Math.max(0, 3 - previewImages.length) }).map((_, i) => (
                  <div
                    key={`ph-${i}`}
                    className="aspect-square rounded-xl flex items-center justify-center text-2xl cursor-pointer border-2 border-dashed transition-colors duration-200"
                    style={{
                      background: 'linear-gradient(135deg, #E8D5F5, #DDB8F5)',
                      borderColor: 'var(--lavender)',
                      color: 'var(--plum)',
                    }}
                    onClick={() => fileInputRef.current?.click()}
                    onMouseEnter={e => {
                      (e.currentTarget as HTMLElement).style.background = 'var(--lavender)'
                    }}
                    onMouseLeave={e => {
                      (e.currentTarget as HTMLElement).style.background =
                        'linear-gradient(135deg, #E8D5F5, #DDB8F5)'
                    }}
                  >+</div>
                ))}
              </div>

              {/* Keywords */}
              <SectionLabel>Quick Keywords</SectionLabel>
              <div className="flex flex-wrap gap-2 mb-5">
                {KEYWORDS.map(kw => {
                  const active = selectedKeywords.has(kw)
                  return (
                    <div
                      key={kw}
                      className="border-2 rounded-[20px] px-4 py-2 text-[13px] font-semibold cursor-pointer transition-all duration-200"
                      style={{
                        fontFamily: 'var(--font-syne)',
                        background: active ? 'var(--plum)' : 'white',
                        borderColor: active ? 'var(--plum)' : 'var(--lavender)',
                        color: active ? 'white' : 'var(--charcoal)',
                      }}
                      onClick={() => toggleKeyword(kw)}
                      onMouseEnter={e => {
                        if (!active)
                          (e.currentTarget as HTMLElement).style.borderColor = 'var(--plum-mid)'
                      }}
                      onMouseLeave={e => {
                        if (!active)
                          (e.currentTarget as HTMLElement).style.borderColor = 'var(--lavender)'
                      }}
                    >{kw}</div>
                  )
                })}
              </div>

              {/* Color palette */}
              <SectionLabel>Event Color Palette</SectionLabel>
              <div className="flex gap-3 flex-wrap">
                {COLOR_SWATCHES.map(({ color, name, hasBorder }) => {
                  const active = selectedColors.includes(name)
                  return (
                    <button
                      key={name}
                      title={name}
                      className="w-10 h-10 rounded-full cursor-pointer transition-all duration-200 flex-shrink-0"
                      style={{
                        background: color,
                        border: active
                          ? '3px solid var(--charcoal)'
                          : hasBorder
                          ? '3px solid #ddd'
                          : '3px solid transparent',
                        transform: active ? 'scale(1.18)' : 'scale(1)',
                      }}
                      onClick={() => toggleColor(name)}
                    />
                  )
                })}
              </div>
            </div>
          }
          footer={
            <>
              <NavDots active={1} />
              <NextBtn label="Continue →" onClick={() => setScreen(3)} />
            </>
          }
        />
      )}

      {/* ── SCREEN 3: DATE & LOGISTICS ───────────────────────────────────── */}
      {screen === 3 && (
        <StepShell
          header={
            <>
              <ProgressBar done={3} />
              <BackBtn onClick={() => setScreen(2)} />
              <div className="text-[11px] tracking-[2px] uppercase mb-1" style={{ color: 'var(--muted)' }}>
                Step 3 of 6
              </div>
              <div
                className="text-[26px] font-bold tracking-[-0.5px] leading-tight"
                style={{ fontFamily: 'var(--font-syne)', color: 'var(--charcoal)' }}
              >When &amp; where is it?</div>
            </>
          }
          body={
            <div className="pt-2 pb-4 space-y-4">
              {/* Event date */}
              <div>
                <label
                  className="text-[12px] font-medium tracking-[0.5px] mb-2 block"
                  style={{ color: 'var(--muted)' }}
                >Event Date</label>
                <InputField
                  type="date"
                  value={eventDate}
                  onChange={e => setEventDate(e.target.value)}
                />
              </div>

              {/* Destination or local */}
              <div>
                <label
                  className="text-[12px] font-medium tracking-[0.5px] mb-2 block"
                  style={{ color: 'var(--muted)' }}
                >Is this a destination event?</label>
                <div className="flex gap-3">
                  {(
                    [
                      { label: 'Destination', icon: '✈️', val: true  },
                      { label: 'Local',        icon: '📍', val: false },
                    ] as const
                  ).map(({ label, icon, val }) => (
                    <div
                      key={label}
                      className="flex-1 bg-white border-2 rounded-2xl p-4 cursor-pointer transition-all duration-200 hover:-translate-y-px"
                      style={{
                        borderColor: isDestination === val ? 'var(--plum)' : 'transparent',
                        background: isDestination === val ? 'var(--lavender-light)' : 'white',
                        boxShadow: '0 2px 12px rgba(74,14,110,0.07)',
                      }}
                      onClick={() => setIsDestination(val)}
                      onMouseEnter={e => {
                        if (isDestination !== val)
                          (e.currentTarget as HTMLElement).style.borderColor = 'var(--lavender)'
                      }}
                      onMouseLeave={e => {
                        if (isDestination !== val)
                          (e.currentTarget as HTMLElement).style.borderColor = 'transparent'
                      }}
                    >
                      <span className="text-[20px] mb-1 block">{icon}</span>
                      <div
                        className="text-[13px] font-bold"
                        style={{ fontFamily: 'var(--font-syne)', color: 'var(--charcoal)' }}
                      >{label}</div>
                    </div>
                  ))}
                </div>
              </div>

              {/* Location */}
              <div>
                <label
                  className="text-[12px] font-medium tracking-[0.5px] mb-2 block"
                  style={{ color: 'var(--muted)' }}
                >City, State or Country</label>
                <InputField
                  type="text"
                  placeholder="e.g. Houston TX  |  Lake Como, Italy"
                  value={location}
                  onChange={e => setLocation(e.target.value)}
                />
              </div>

              {/* Guest count + duration */}
              <div className="grid grid-cols-2 gap-3">
                <div>
                  <label
                    className="text-[12px] font-medium tracking-[0.5px] mb-2 block"
                    style={{ color: 'var(--muted)' }}
                  >Guest Count</label>
                  <InputField
                    type="number"
                    placeholder="e.g. 150"
                    value={guestCount}
                    onChange={e => setGuestCount(e.target.value)}
                  />
                </div>
                <div>
                  <label
                    className="text-[12px] font-medium tracking-[0.5px] mb-2 block"
                    style={{ color: 'var(--muted)' }}
                  >Duration</label>
                  <select
                    className="w-full bg-white border-2 rounded-2xl px-4 py-4 text-[15px] outline-none transition-colors duration-200 appearance-none"
                    style={{
                      fontFamily: 'var(--font-space)',
                      color: 'var(--charcoal)',
                      borderColor: 'var(--lavender)',
                      boxShadow: '0 2px 8px rgba(74,14,110,0.04)',
                    }}
                    value={duration}
                    onChange={e => setDuration(e.target.value)}
                    onFocus={e => { e.currentTarget.style.borderColor = 'var(--plum)' }}
                    onBlur={e => { e.currentTarget.style.borderColor = 'var(--lavender)' }}
                  >
                    <option value="" disabled>Select</option>
                    <option>2–3 hrs</option>
                    <option>4–5 hrs</option>
                    <option>Full day</option>
                    <option>Multi-day</option>
                    <option>Weekend</option>
                  </select>
                </div>
              </div>

              {/* Special requirements */}
              <div>
                <label
                  className="text-[12px] font-medium tracking-[0.5px] mb-2 block"
                  style={{ color: 'var(--muted)' }}
                >Any special requirements?</label>
                <InputField
                  type="text"
                  placeholder="e.g. Halal food, wheelchair access, kids zone…"
                  value={requirements}
                  onChange={e => setRequirements(e.target.value)}
                />
              </div>
            </div>
          }
          footer={
            <>
              <NavDots active={2} />
              <NextBtn label="Continue →" onClick={() => setScreen(4)} />
            </>
          }
        />
      )}

      {/* ── SCREEN 4: BUDGET ─────────────────────────────────────────────── */}
      {screen === 4 && (
        <StepShell
          header={
            <>
              <ProgressBar done={4} />
              <BackBtn onClick={() => setScreen(3)} />
              <div className="text-[11px] tracking-[2px] uppercase mb-1" style={{ color: 'var(--muted)' }}>
                Step 4 of 6
              </div>
              <div
                className="text-[26px] font-bold tracking-[-0.5px] leading-tight"
                style={{ fontFamily: 'var(--font-syne)', color: 'var(--charcoal)' }}
              >What&apos;s your budget?</div>
              <div className="text-[14px] mt-2 leading-[1.55]" style={{ color: 'var(--muted)' }}>
                We&apos;ll match you with vendors at every price point.
              </div>
            </>
          }
          body={
            <div className="pt-2 pb-4">
              {/* Budget display */}
              <div
                className="rounded-2xl p-6 text-center mb-5"
                style={{ background: 'var(--plum)' }}
              >
                <div
                  className="text-[42px] font-extrabold text-white tracking-[-1.5px]"
                  style={{ fontFamily: 'var(--font-syne)' }}
                >${budget.toLocaleString()}</div>
                <div className="text-[11px] text-white/50 tracking-[1.5px] uppercase mt-1">
                  Total Budget
                </div>
              </div>

              {/* Range slider */}
              <input
                type="range"
                min={500}
                max={500000}
                step={500}
                value={budget}
                onChange={e => setBudget(Number(e.target.value))}
                className="budget-range"
              />

              {/* Budget presets */}
              <div className="flex gap-2 mb-6">
                {BUDGET_PRESETS.map(({ label, value }) => {
                  const active = budget === value
                  return (
                    <div
                      key={label}
                      className="flex-1 bg-white border-2 rounded-xl py-2.5 px-1 text-[11px] font-bold text-center cursor-pointer transition-all duration-200"
                      style={{
                        fontFamily: 'var(--font-syne)',
                        borderColor: active ? 'var(--plum)' : 'var(--lavender)',
                        color: active ? 'var(--plum)' : 'var(--muted)',
                        background: active ? 'var(--lavender-light)' : 'white',
                      }}
                      onClick={() => setBudget(value)}
                      onMouseEnter={e => {
                        if (!active) {
                          const el = e.currentTarget as HTMLElement
                          el.style.borderColor = 'var(--plum)'
                          el.style.color = 'var(--plum)'
                          el.style.background = 'var(--lavender-light)'
                        }
                      }}
                      onMouseLeave={e => {
                        if (!active) {
                          const el = e.currentTarget as HTMLElement
                          el.style.borderColor = 'var(--lavender)'
                          el.style.color = 'var(--muted)'
                          el.style.background = 'white'
                        }
                      }}
                    >{label}</div>
                  )
                })}
              </div>

              {/* Event tier */}
              <SectionLabel>Event Tier</SectionLabel>
              <div className="grid grid-cols-2 gap-3">
                {TIERS.map(({ icon, name, range }) => {
                  const active = selectedTier === name
                  return (
                    <div
                      key={name}
                      className="bg-white border-2 rounded-2xl p-4 cursor-pointer transition-all duration-200"
                      style={{
                        borderColor: active ? 'var(--plum)' : 'var(--lavender)',
                        background: active ? 'var(--lavender-light)' : 'white',
                        boxShadow: '0 2px 12px rgba(74,14,110,0.07)',
                      }}
                      onClick={() => setSelectedTier(name)}
                      onMouseEnter={e => {
                        if (!active)
                          (e.currentTarget as HTMLElement).style.borderColor = 'var(--plum-mid)'
                      }}
                      onMouseLeave={e => {
                        if (!active)
                          (e.currentTarget as HTMLElement).style.borderColor = 'var(--lavender)'
                      }}
                    >
                      <div className="text-[24px] mb-2">{icon}</div>
                      <div
                        className="text-[14px] font-bold"
                        style={{ fontFamily: 'var(--font-syne)', color: 'var(--charcoal)' }}
                      >{name}</div>
                      <div className="text-[12px] mt-0.5" style={{ color: 'var(--muted)' }}>{range}</div>
                    </div>
                  )
                })}
              </div>
            </div>
          }
          footer={
            <>
              <NavDots active={3} />
              <NextBtn label="Continue →" onClick={() => setScreen(5)} />
            </>
          }
        />
      )}

      {/* ── SCREEN 5: AI REVIEW / CONFIRM ────────────────────────────────── */}
      {screen === 5 && (
        <StepShell
          header={
            <>
              <ProgressBar done={5} />
              <BackBtn onClick={() => setScreen(4)} />
              <div className="text-[11px] tracking-[2px] uppercase mb-1" style={{ color: 'var(--muted)' }}>
                Step 5 of 6
              </div>
              <div
                className="text-[26px] font-bold tracking-[-0.5px] leading-tight"
                style={{ fontFamily: 'var(--font-syne)', color: 'var(--charcoal)' }}
              >Here&apos;s what we&apos;ve got. Look good?</div>
            </>
          }
          body={
            <div className="pt-2 pb-4">
              {/* AI note */}
              <div
                className="border-l-[3px] rounded-r-xl px-4 py-3.5 text-[14px] leading-[1.65] mb-4 italic"
                style={{
                  background: 'var(--lavender-light)',
                  borderColor: 'var(--plum)',
                  color: 'var(--charcoal)',
                }}
              >
                ✦ Based on your description, I&apos;m curating{' '}
                {dreamText
                  ? 'an event tailored to your vision'
                  : 'an intimate candlelit outdoor dinner with luxury vendors, Afrobeats playlist, and full-service bar'}{' '}
                — all within your budget.
              </div>

              {/* Confirm card */}
              <div
                className="bg-white rounded-2xl p-5 mb-4"
                style={{ boxShadow: '0 2px 12px rgba(74,14,110,0.07)' }}
              >
                {[
                  { icon: '🎉', key: 'Event Type',    val: eventType || 'Birthday Party' },
                  { icon: '📍', key: 'Location',      val: location  || 'Houston, TX' },
                  {
                    icon: '📅',
                    key: 'Date & Guests',
                    val: `${eventDate || 'June 14, 2025'} · ${guestCount || '80'} guests`,
                  },
                  {
                    icon: '💰',
                    key: 'Budget · Tier',
                    val: `$${budget.toLocaleString()} · ${selectedTier || 'Luxury'}`,
                  },
                ].map(({ icon, key, val }) => (
                  <div key={key} className="flex items-start gap-3.5 mb-3.5 last:mb-0">
                    <div
                      className="w-9 h-9 rounded-xl flex items-center justify-center text-base flex-shrink-0"
                      style={{ background: 'var(--lavender-light)' }}
                    >{icon}</div>
                    <div>
                      <div className="text-[11px] tracking-[0.5px]" style={{ color: 'var(--muted)' }}>{key}</div>
                      <div
                        className="text-[14px] font-bold mt-0.5"
                        style={{ fontFamily: 'var(--font-syne)', color: 'var(--charcoal)' }}
                      >{val}</div>
                    </div>
                  </div>
                ))}
              </div>

              {/* Mood board preview */}
              <SectionLabel>Your Mood Board</SectionLabel>
              <div className="flex gap-2 mb-4 overflow-x-auto pb-1 scrollbar-hide">
                {moodThumbs.map((emoji, i) => (
                  <div
                    key={i}
                    className="w-[72px] h-[72px] rounded-xl flex-shrink-0 flex items-center justify-center text-[26px]"
                    style={{ background: 'linear-gradient(135deg, #E8D5F5, #C4A0E8)' }}
                  >{emoji}</div>
                ))}
              </div>

              {/* Selected keywords */}
              <SectionLabel>Selected Keywords</SectionLabel>
              <div className="flex flex-wrap gap-2">
                {(selectedKeywords.size > 0
                  ? Array.from(selectedKeywords)
                  : ['Candlelit', 'Outdoor', 'Fairy Lights', 'Dance Floor']
                ).map(kw => (
                  <div
                    key={kw}
                    className="border-2 text-white rounded-[20px] px-4 py-2 text-[13px] font-semibold"
                    style={{
                      fontFamily: 'var(--font-syne)',
                      background: 'var(--plum)',
                      borderColor: 'var(--plum)',
                    }}
                  >{kw}</div>
                ))}
              </div>
            </div>
          }
          footer={
            <>
              <NavDots active={4} />
              <NextBtn
                label={generating ? 'Saving…' : 'Generate My Event Plan ✦'}
                onClick={handleGenerate}
                disabled={generating}
              />
            </>
          }
        />
      )}

      {/* ── SCREEN 6: AI GENERATING ──────────────────────────────────────── */}
      {screen === 6 && (
        <div
          className="min-h-screen flex flex-col items-center justify-center px-6 py-16 text-center animate-slide-in"
          style={{ background: 'var(--plum)' }}
        >
          <div className="w-full max-w-[480px]">
            <div
              className="w-[100px] h-[100px] rounded-full bg-white/[0.12] flex items-center justify-center text-[44px] mb-8 mx-auto"
              style={{ animation: 'pulseOrb 2s ease-in-out infinite' }}
            >✦</div>
            <div
              className="text-[32px] font-extrabold text-white tracking-[-0.5px] mb-3"
              style={{ fontFamily: 'var(--font-syne)' }}
            >Building your event…</div>
            <div className="text-[15px] text-white/60 leading-[1.65] mb-10">
              Our AI is analyzing your vision and curating the perfect vendors,
              timeline and budget breakdown.
            </div>
            <div className="text-left">
              {[
                { icon: '🖼️', text: 'Analyzing your mood board',                           done: true,  delay: 0   },
                { icon: '📍', text: `Finding vendors in ${location || 'your city'}`,        done: true,  delay: 0.5 },
                { icon: '💰', text: `Matching to your $${budget.toLocaleString()} budget`,  done: true,  delay: 1   },
                { icon: '✨', text: 'Curating luxury vendor shortlist',                      done: false, delay: 1.5 },
                { icon: '📋', text: 'Building your event timeline',                          done: false, delay: 2   },
              ].map(({ icon, text, done, delay }, i) => (
                <div
                  key={i}
                  className="flex items-center gap-4 px-5 py-4 bg-white/[0.08] rounded-2xl mb-3"
                  style={{ animation: `fadeUp 0.5s ${delay}s ease both` }}
                >
                  <span className="text-[18px]">{icon}</span>
                  <span className="text-[14px] text-white/85 font-medium">{text}</span>
                  <div className="ml-auto w-6 h-6 rounded-full bg-white/[0.15] flex items-center justify-center text-[11px] text-white flex-shrink-0">
                    {done ? '✓' : '⋯'}
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      )}
    </div>
  )
}
